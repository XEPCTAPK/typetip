{
    "compilerOptions": {
        "module": "Node16",
        "moduleResolution": "Node16",
        "target": "ES2022",
        "outDir": "out",
        "rootDir": "src",
        "skipLibCheck": true, // Чтобы компилятор перестал проверять чужие папки
        "lib": [
            "ES2022"
        ],
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "types": [
            "node",
            "mocha",
            "vscode"
        ]
    }
}